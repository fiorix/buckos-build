load("//defs:package.bzl", "package")

# xxd - Hexdump utility from Vim
# xxd uses a simple Makefile, not autoconf

package(
    name = "xxd",
    build_rule = "autotools",
    skip_configure = True,
    version = "9.1.0",
    source = "//packages/linux/editors/vim:vim-src",
    description = "Hexdump utility from Vim",
    homepage = "https://www.vim.org/",
    license = "GPL-2+",
    post_install_cmds = ["""\
cd src/xxd
        install -Dm755 xxd "$DESTDIR/usr/bin/xxd"
        # Man page is in runtime/doc/, not src/xxd/
        install -Dm644 ../../runtime/doc/xxd.1 "$DESTDIR/usr/share/man/man1/xxd.1"
"""],
)
