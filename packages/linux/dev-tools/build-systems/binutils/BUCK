load("//defs:package.bzl", "package")

package(
    build_rule = "autotools",
    name = "binutils",
    version = "2.44",
    url = "https://mirrors.kernel.org/gnu/binutils/binutils-2.44.tar.xz",
    sha256 = "ce2017e059d63e67ddb9240e9d4ec49c2893605035cd60e92ad53177f4377237",
    description = "GNU binary utilities",
    homepage = "https://www.gnu.org/software/binutils/",
    license = "GPL-3.0-or-later",

    # binutils' multi-directory build system (gas, ld, libbfd) breaks when
    # --host/--build are set: make install triggers a full rebuild that
    # creates a truncated libbfd.a.  Cross-compiler --sysroot provides
    # the actual hermeticity boundary — skip_host_arg is safe here.
    skip_host_arg = True,
    skip_cc_auto_arg = True,
    configure_args = [
        "--disable-nls",
        "--disable-werror",
        "--enable-gprofng=no",
        "--disable-gprof",
        "--disable-gdb",
        "--disable-shared",
        "--without-xxhash",
    ],

)
