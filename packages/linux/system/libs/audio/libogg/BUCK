load("//defs:package.bzl", "package")

package(
    build_rule = "autotools",
    name = "libogg",
    source = "//packages/linux/media/audio/ogg:ogg-src",
    use_configure = {
        "static-libs": ("--enable-static", "--disable-static"),
    },
    version = "1.3.5",
    description = "Ogg bitstream and framing library",
    homepage = "https://xiph.org/ogg/",
    license = "BSD-3-Clause",
    configure_args = [
        "--disable-static",
    ],
    libraries = ["ogg"],
    # Skip test programs — they fail to link in the install phase
    # because the build dir is a read-only Buck2 artifact.
    make_args = ["noinst_PROGRAMS="],
    post_install_cmds = [
        "find . -name '*.la' -delete || true",
    ],
)
